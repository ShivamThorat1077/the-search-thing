{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "opennextjs-cloudflare build",
    "build:next": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
